# ============================================================
# Alyto Frontend V2.0 — .env.example
# Copiar a .env y completar con valores reales.
# ⚠ NUNCA commitear el archivo .env — contiene secretos.
# ============================================================

# ── Stripe Identity (Frontend) ──────────────────────────────
# Clave PÚBLICA de Stripe — visible en Dashboard → Developers → API keys
# Formato: pk_test_... (test) o pk_live_... (producción)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Backend API ─────────────────────────────────────────────
# URL base del backend (sin slash al final)
VITE_API_URL=http://localhost:3000/api/v1
# Producción:
# VITE_API_URL=https://api.alyto.io/api/v1

# ── Sentry (monitoreo de errores frontend) ──────────────────
# Obtener en sentry.io → Create Project → React (Browser) → DSN
# Recomendado: proyecto SEPARADO del backend para distinguir
# errores de interfaz de errores de servidor en el dashboard
# Formato: https://xxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
# Dejar vacío para deshabilitar (desarrollo local sin cuenta)
VITE_SENTRY_DSN=

# ── Firebase Cloud Messaging (Push Notifications) ────────────
# VAPID key: Firebase Console → Project Settings → Cloud Messaging
#            → Web configuration → Web Push certificates → Key pair
# Sin esta key, getToken() devuelve null y push no funciona.
VITE_FIREBASE_VAPID_KEY=

# ── Soporte al usuario ───────────────────────────────────────
# Número de WhatsApp de soporte (incluir código de país, sin espacios)
# Se usa en TransactionDetail cuando una transferencia falla.
VITE_SUPPORT_WHATSAPP=+56949705364
