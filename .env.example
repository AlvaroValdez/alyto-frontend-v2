# ============================================================
# Alyto Frontend V2.0 — .env.example
# Copiar a .env y completar con valores reales.
# ⚠ NUNCA commitear el archivo .env (está en .gitignore).
#
# NOTA DE SEGURIDAD: todas las variables VITE_* se INCRUSTAN en el bundle del
# navegador — son PÚBLICAS por diseño (identificadores de cliente, no secretos).
# NUNCA poner aquí una clave secreta de servidor (sk_..., service account, etc.).
# La seguridad se aplica del lado backend y con reglas/restricciones del proveedor
# (Firebase Security Rules + App Check, restricción por dominio de la API key,
# restricción de dominio de la pk de Stripe).
# ============================================================

# ── Stripe Identity (Frontend) ──────────────────────────────
# Clave PÚBLICA de Stripe — visible en Dashboard → Developers → API keys
# Formato: pk_test_... (test) o pk_live_... (producción)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Backend API ─────────────────────────────────────────────
# URL base del backend (sin slash al final)
VITE_API_URL=http://localhost:3000/api/v1
# Producción: VITE_API_URL=https://api.alyto.app/api/v1

# WebSocket de cotizaciones en tiempo real
VITE_WS_URL=ws://localhost:3000/ws/quote
# Producción: VITE_WS_URL=wss://api.alyto.app/ws/quote

# ── Sentry (monitoreo de errores frontend) ──────────────────
# DSN público de Sentry (se incrusta en el cliente). Proyecto SEPARADO del backend.
# Formato: https://xxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
# Dejar vacío para deshabilitar (desarrollo local sin cuenta)
VITE_SENTRY_DSN=

# ── Firebase Cloud Messaging (Push Notifications) ────────────
# Config WEB de Firebase (Console → Project Settings → General → tus apps → Web).
# TODOS estos valores son públicos por diseño (van en el bundle y en el
# service worker public/firebase-messaging-sw.js). Restringir la API key por
# dominio HTTP + activar App Check para el hardening.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VAPID key (clave PÚBLICA de Web Push): Console → Cloud Messaging → Web Push certificates
# Sin esta key, getToken() devuelve null y push no funciona.
VITE_FIREBASE_VAPID_KEY=

# ── Sesión ───────────────────────────────────────────────────
# Tiempo de inactividad antes de mostrar modal (ms). Default: 30 min
VITE_INACTIVITY_TIMEOUT_MS=1800000

# ── Soporte al usuario ───────────────────────────────────────
# Número de WhatsApp de soporte (incluir código de país, sin espacios)
VITE_SUPPORT_WHATSAPP=+56988321490
